+    def filter_by_success_ratio(self, target_success_ratio: float, rng=None) -> None:
+        """Drop failed trajectories until success/(success+fail) >= target_success_ratio.
+
+        Operates on the in-memory index only; no files are modified.
+        A trajectory is considered successful if any reward value equals 0.
+        """
+        import random as _random
+
+        success_ids, fail_ids = [], []
+        for tid in list(self._trajectory_id_list):
+            pt_path = self._get_trajectory_path(
+                tid,
+                self._trajectory_index[tid]["model_weights_id"],
+                base_dir=self._trajectory_file_path[tid],
+            )
+            traj = torch.load(pt_path, map_location="cpu", weights_only=False)
+            rewards = traj["rewards"]
+            if (rewards == 0).any():
+                success_ids.append(tid)
+            else:
+                fail_ids.append(tid)
+
+        n_success = len(success_ids)
+        if n_success == 0 or target_success_ratio <= 0:
+            return
+
+        # How many fail trajectories to keep
+        # n_success / (n_success + n_fail_keep) >= ratio  →  n_fail_keep <= n_success*(1-ratio)/ratio
+        n_fail_keep = int(n_success * (1.0 - target_success_ratio) / target_success_ratio)
+        n_fail_keep = max(0, min(n_fail_keep, len(fail_ids)))
+
+        rng_obj = rng or _random.Random(self.seed)
+        keep_fail = set(rng_obj.sample(fail_ids, n_fail_keep))
+        remove_ids = [tid for tid in fail_ids if tid not in keep_fail]
+
+        for tid in remove_ids:
+            self._trajectory_index.pop(tid, None)
+            self._trajectory_file_path.pop(tid, None)
+        self._trajectory_id_list = [
+            tid for tid in self._trajectory_id_list if tid not in set(remove_ids)
+        ]
+        self.size = len(self._trajectory_id_list)
+        self._total_samples = sum(
+            info.get("num_samples", 0) for info in self._trajectory_index.values()
+        )
+
+        actual_ratio = n_success / self.size if self.size > 0 else 0.0
+        import logging
+        logging.getLogger(__name__).info(
+            f"filter_by_success_ratio: kept {n_success} success + {n_fail_keep} fail "
+            f"({actual_ratio:.1%} success), removed {len(remove_ids)} fail trajectories"
+        )
+
+        if self._flat_trajectory_cache is not None:
+            self._flat_trajectory_cache.clear()
+
     def clear_cache(self):
         """Clear trajectory cache."""
         self.close()
