+    def _extract_critic_context_pair(
+        self,
+        forward_inputs_a: dict[str, torch.Tensor],
+        forward_inputs_b: dict[str, torch.Tensor],
+    ) -> tuple[dict[str, torch.Tensor], dict[str, torch.Tensor]]:
+        """Fused ALOE_CRITIC forward for two batches; splits output back.
+
+        Reduces critic-step VLM calls from 2 to 1 by concatenating next and curr
+        forward_inputs along the batch dimension before calling the model.
+        Falls back to two separate calls if tensor shapes differ across inputs
+        (e.g., tokenized_prompt length mismatch across replay trajectories).
+        NOTE: safe only when critic_batch_size * 2 fits in VRAM (H800 ok up to ~128).
+        """
+        if not self._critic_use_pi05_context:
+            return {}, {}
+
+        first_key = next(iter(forward_inputs_a))
+        B_a = forward_inputs_a[first_key].shape[0]
+        B_b = forward_inputs_b[first_key].shape[0]
+
+        common_keys = set(forward_inputs_a) & set(forward_inputs_b)
+        shapes_match = all(
+            forward_inputs_a[k].shape[1:] == forward_inputs_b[k].shape[1:]
+            for k in common_keys
+            if torch.is_tensor(forward_inputs_a[k])
+        )
+        if not shapes_match:
+            return (
+                self._extract_critic_context(forward_inputs_a),
+                self._extract_critic_context(forward_inputs_b),
+            )
+
+        merged = {
+            k: torch.cat([forward_inputs_a[k], forward_inputs_b[k]], dim=0)
+            for k in common_keys
+            if torch.is_tensor(forward_inputs_a[k])
+        }
+        was_training = self.model.training
+        self.model.eval()
+        # extract_aloe_critic_context carries @torch.no_grad(); no extra wrapper needed.
+        context = self.model(
+            forward_type=ForwardType.ALOE_CRITIC,
+            forward_inputs=merged,
+        )
+        if was_training:
+            self.model.train()
+        context = put_tensor_device(context, self.device)
+        ctx_a = {k: v[:B_a] for k, v in context.items()}
+        ctx_b = {k: v[B_a : B_a + B_b] for k, v in context.items()}
+        return ctx_a, ctx_b
+
