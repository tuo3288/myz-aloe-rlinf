@@ -0,0 +1,99 @@
+#!/usr/bin/env bash
+#
+# train_critic.sh — paper Algorithm L4-L9: N_Q critic gradient steps + Polyak.
+#
+# Underlying:    examples/embodiment/train_offline_rl.py
+# Mode:          critic-only (algorithm.aloe.N_Q=1, N_pi=0; one outer step ≡
+#                one critic gradient step per _design.md §1).
+#
+# Cosine LR:
+#   default     — global cosine over --global-cosine-total steps (state resumed)
+#   --reset-cosine — sets actor.critic_optim.reset_scheduler_on_load=True;
+#                  scheduler reconstructed each call with last_epoch=0 (Patch B).
+#
+# CLI
+#   --resume-dir DIR              previous phase ckpt                              (required)
+#   --max-steps N                 DELTA: critic grad steps for THIS call           (required)
+#   --save-interval K             default = DELTA  (single end-of-call save)
+#   --reset-cosine                per-call cosine restart
+#   --global-cosine-total N       default = DELTA when --reset-cosine is unset
+#   --suite NAME                  default libero_goal
+#   --log-dir DIR                 per-run dir                                       (required)
+#   --exp-name NAME
+#   --seed N                      default 42
+#   --                            hydra passthrough
+#
+# Env: requires ALOE_PI05_MODEL_PATH; honours ALOE_GPUS, ALOE_BETA.
+
+source "$(dirname "$0")/lib/common.sh"
+
+RESUME_DIR=""
+DELTA=""
+SAVE_INTERVAL=""
+RESET_COSINE=0
+GLOBAL_COSINE_TOTAL=""
+SUITE="$aloe_default_suite"
+LOG_DIR=""
+EXP_NAME=""
+SEED=$aloe_default_seed
+HYDRA_PASSTHROUGH=()
+
+while [[ $# -gt 0 ]]; do
+    case "$1" in
+        --resume-dir) RESUME_DIR="$2"; shift 2 ;;
+        --max-steps) DELTA="$2"; shift 2 ;;
+        --save-interval) SAVE_INTERVAL="$2"; shift 2 ;;
+        --reset-cosine) RESET_COSINE=1; shift ;;
+        --global-cosine-total) GLOBAL_COSINE_TOTAL="$2"; shift 2 ;;
+        --suite) SUITE="$2"; shift 2 ;;
+        --log-dir) LOG_DIR="$2"; shift 2 ;;
+        --exp-name) EXP_NAME="$2"; shift 2 ;;
+        --seed) SEED="$2"; shift 2 ;;
+        --) shift; HYDRA_PASSTHROUGH=("$@"); break ;;
+        -h|--help) sed -n '3,28p' "$0"; exit 0 ;;
+        *) aloe_die "unknown arg: $1" ;;
+    esac
+done
+
+[[ -n "$RESUME_DIR" ]] || aloe_die "--resume-dir is required"
+[[ -n "$DELTA"      ]] || aloe_die "--max-steps is required"
+[[ -n "$LOG_DIR"    ]] || aloe_die "--log-dir is required"
+aloe_assert_ckpt "$RESUME_DIR"
+[[ -z "$EXP_NAME" ]] && EXP_NAME=$(aloe_default_exp_name "critic_seed${SEED}")
+[[ -z "$SAVE_INTERVAL" ]] && SAVE_INTERVAL="$DELTA"
+
+RESUME_STEP=$(aloe_parse_global_step "$RESUME_DIR")
+ABS_MAX=$(( RESUME_STEP + DELTA ))
+
+if [[ "$RESET_COSINE" == "1" ]]; then
+    COSINE_T="$DELTA"
+    COSINE_MODE_STR="per-call restart"
+    # `+key=` syntax adds the field; the yaml schema is strict-mode and
+    # `reset_scheduler_on_load` is not declared as a default field there.
+    COSINE_FLAG=("+actor.critic_optim.reset_scheduler_on_load=True")
+else
+    COSINE_T="${GLOBAL_COSINE_TOTAL:-$DELTA}"
+    COSINE_MODE_STR="global (resume scheduler state)"
+    COSINE_FLAG=("+actor.critic_optim.reset_scheduler_on_load=False")
+fi
+
+aloe_init_log_dir "$LOG_DIR"
+aloe_log "critic: suite=${SUITE} resume@global_step_${RESUME_STEP} +${DELTA} → global_step_${ABS_MAX}"
+aloe_log "        save_interval=${SAVE_INTERVAL}  cosine=${COSINE_MODE_STR}  T_max=${COSINE_T}"
+
+mapfile -t BASE_OVERRIDES < <(aloe_base_overrides "$LOG_DIR" "$EXP_NAME" "$SUITE")
+
+aloe_run train_offline_rl.py "$LOG_DIR" \
+    "algorithm.aloe.N_Q=1" \
+    "algorithm.aloe.N_pi=0" \
+    "runner.max_steps=${ABS_MAX}" \
+    "runner.max_epochs=${ABS_MAX}" \
+    "runner.save_interval=${SAVE_INTERVAL}" \
+    "runner.val_check_interval=-1" \
+    "runner.only_eval=False" \
+    "actor.critic_optim.num_training_steps=${COSINE_T}" \
+    "${COSINE_FLAG[@]}" \
+    "runner.resume_dir=${RESUME_DIR}" \
+    "actor.seed=${SEED}" \
+    "${BASE_OVERRIDES[@]}" \
+    "${HYDRA_PASSTHROUGH[@]}"
