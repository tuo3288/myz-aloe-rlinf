+++ b/examples/aloe/train_actor.sh
@@ -0,0 +1,81 @@
+#!/usr/bin/env bash
+#
+# train_actor.sh — paper Algorithm L10-L15: N_π AWR-weighted flow updates.
+#
+# Underlying:    examples/embodiment/train_offline_rl.py
+# Mode:          actor-only (algorithm.aloe.N_Q=0, N_pi=1; one outer step ≡
+#                one actor gradient step).
+#
+# Note: actor optimizer has no LR scheduler in current code. --reset-cosine /
+#       --global-cosine-total are silently ignored (warned).
+#
+# CLI
+#   --resume-dir DIR              previous phase ckpt                              (required)
+#   --max-steps N                 DELTA: actor grad steps for THIS call            (required)
+#   --save-interval K             default = DELTA
+#   --suite NAME                  default libero_goal
+#   --log-dir DIR                 per-run dir                                       (required)
+#   --exp-name NAME
+#   --seed N                      default 42
+#   --                            hydra passthrough
+#
+# Env: requires ALOE_PI05_MODEL_PATH; honours ALOE_GPUS, ALOE_BETA.
+
+source "$(dirname "$0")/lib/common.sh"
+
+RESUME_DIR=""
+DELTA=""
+SAVE_INTERVAL=""
+SUITE="$aloe_default_suite"
+LOG_DIR=""
+EXP_NAME=""
+SEED=$aloe_default_seed
+HYDRA_PASSTHROUGH=()
+
+while [[ $# -gt 0 ]]; do
+    case "$1" in
+        --resume-dir) RESUME_DIR="$2"; shift 2 ;;
+        --max-steps) DELTA="$2"; shift 2 ;;
+        --save-interval) SAVE_INTERVAL="$2"; shift 2 ;;
+        --suite) SUITE="$2"; shift 2 ;;
+        --log-dir) LOG_DIR="$2"; shift 2 ;;
+        --exp-name) EXP_NAME="$2"; shift 2 ;;
+        --seed) SEED="$2"; shift 2 ;;
+        --reset-cosine|--global-cosine-total)
+            aloe_warn "actor optim has no LR scheduler; ignoring $1"
+            [[ "$1" == "--global-cosine-total" ]] && shift
+            shift ;;
+        --) shift; HYDRA_PASSTHROUGH=("$@"); break ;;
+        -h|--help) sed -n '3,22p' "$0"; exit 0 ;;
+        *) aloe_die "unknown arg: $1" ;;
+    esac
+done
+
+[[ -n "$RESUME_DIR" ]] || aloe_die "--resume-dir is required"
+[[ -n "$DELTA"      ]] || aloe_die "--max-steps is required"
+[[ -n "$LOG_DIR"    ]] || aloe_die "--log-dir is required"
+aloe_assert_ckpt "$RESUME_DIR"
+[[ -z "$EXP_NAME" ]] && EXP_NAME=$(aloe_default_exp_name "actor_seed${SEED}")
+[[ -z "$SAVE_INTERVAL" ]] && SAVE_INTERVAL="$DELTA"
+
+RESUME_STEP=$(aloe_parse_global_step "$RESUME_DIR")
+ABS_MAX=$(( RESUME_STEP + DELTA ))
+
+aloe_init_log_dir "$LOG_DIR"
+aloe_log "actor:  suite=${SUITE} resume@global_step_${RESUME_STEP} +${DELTA} → global_step_${ABS_MAX}"
+aloe_log "        save_interval=${SAVE_INTERVAL}"
+
+mapfile -t BASE_OVERRIDES < <(aloe_base_overrides "$LOG_DIR" "$EXP_NAME" "$SUITE")
+
+aloe_run train_offline_rl.py "$LOG_DIR" \
+    "algorithm.aloe.N_Q=0" \
+    "algorithm.aloe.N_pi=1" \
+    "runner.max_steps=${ABS_MAX}" \
+    "runner.max_epochs=${ABS_MAX}" \
+    "runner.save_interval=${SAVE_INTERVAL}" \
+    "runner.val_check_interval=-1" \
+    "runner.only_eval=False" \
+    "runner.resume_dir=${RESUME_DIR}" \
+    "actor.seed=${SEED}" \
+    "${BASE_OVERRIDES[@]}" \
+    "${HYDRA_PASSTHROUGH[@]}"
